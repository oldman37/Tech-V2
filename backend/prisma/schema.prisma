  performedBy User @relation(fields: [performedById], references: [id])

  @@map("dm_year_rollover_history")
  @@index([schoolYear])
}

// ============================================
// INVENTORY AUDIT (PHYSICAL AUDIT)
// ============================================

model InventoryAuditSession {
  id              String    @id @default(uuid())

  // Scope
  officeLocationId  String
  roomId            String

  // Auditor
  conductedById     String
  conductedByName   String    // Cached display name

  // Timing
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  // Status: IN_PROGRESS | COMPLETED | ABANDONED
  status            String    @default("IN_PROGRESS")

  // Fiscal year (matches purchase_orders pattern)
  fiscalYear        String?

  // Summary counts (denormalized for fast reads)
  totalItems        Int       @default(0)
  presentCount      Int       @default(0)
  missingCount      Int       @default(0)
  unresolvedCount   Int       @default(0)
  additionCount     Int       @default(0)

  // Notes
  notes             String?

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  officeLocation    OfficeLocation  @relation(fields: [officeLocationId], references: [id])
  room              Room            @relation(fields: [roomId], references: [id])
  conductedBy       User            @relation("AuditSessionConductor", fields: [conductedById], references: [id])
  items             InventoryAuditItem[]

  @@index([officeLocationId])
  @@index([roomId])
  @@index([conductedById])
  @@index([status])
  @@index([fiscalYear])
  @@index([startedAt])
  @@index([officeLocationId, roomId, fiscalYear])
  @@map("inventory_audit_sessions")
}

model InventoryAuditItem {
  id              String    @id @default(uuid())

  // Parent session
  sessionId       String

  // Equipment being audited
  equipmentId     String

  // Snapshot of equipment fields at audit time
  equipmentTag    String
  equipmentName   String
  equipmentSerial String?

  // Audit result: PRESENT | MISSING | UNVERIFIED
  status          String

  // Addition flag: true when item was not in original session snapshot but found in room
  isAddition          Boolean   @default(false)

  // Snapshot of where the equipment was assigned BEFORE this audit moved it
  previousRoomId      String?
  previousLocationId  String?

  // Resolution (populated when admin resolves a MISSING item)
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedByName  String?
  resolvedAction  String?
  // FOUND_IN_ROOM | FOUND_ELSEWHERE | CONFIRMED_LOST | EQUIPMENT_UPDATED
  resolutionNotes String?

  // Timestamps
  checkedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  session         InventoryAuditSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  equipment       equipment              @relation(fields: [equipmentId], references: [id])
  resolvedBy      User?                  @relation("AuditItemResolver", fields: [resolvedById], references: [id])

  @@unique([sessionId, equipmentId])
  @@index([sessionId])
  @@index([equipmentId])
  @@index([status])
  @@index([resolvedAt])
  @@index([isAddition])
  @@map("inventory_audit_items")
}

// ============================================
// FISCAL YEAR AUDIT
// ============================================

model FiscalYearAudit {
  id                  String   @id @default(uuid())
  fiscalYear          String   // e.g., "2025-2026"
  status              String   @default("ACTIVE") // ACTIVE | COMPLETED
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  startedById         String
  startedByName       String
  totalLocations      Int      @default(0)
  completedLocations  Int      @default(0)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  startedBy           User     @relation("FiscalYearAuditStartedBy", fields: [startedById], references: [id])
  locationStatuses    FiscalYearLocationStatus[]

  @@unique([fiscalYear])
  @@index([status])
  @@index([fiscalYear])
  @@map("fiscal_year_audits")
}

model FiscalYearLocationStatus {
  id                  String   @id @default(uuid())
  fiscalYearAuditId   String
  officeLocationId    String
  status              String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  completedAt         DateTime?
  completedById       String?
  completedByName     String?
  totalRooms          Int      @default(0)
  auditedRooms        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  fiscalYearAudit     FiscalYearAudit  @relation(fields: [fiscalYearAuditId], references: [id], onDelete: Cascade)
  officeLocation      OfficeLocation   @relation(fields: [officeLocationId], references: [id])
  completedBy         User?            @relation("LocationAuditCompleter", fields: [completedById], references: [id])

  @@unique([fiscalYearAuditId, officeLocationId])
  @@index([fiscalYearAuditId])
  @@index([officeLocationId])
  @@map("fiscal_year_location_statuses")
}

// ============================================
// DEVICE CART (BATCH CHECKOUT)
// ============================================

/// A staging cart that collects multiple devices before committing them as
/// individual DeviceAssignment records in a single atomic transaction.
model DeviceCart {
  id               String    @id @default(uuid())
  /// Asset tag of the physical cart from inventory (set by staff when creating/editing the cart).
  tagNumber        String?   @unique @db.VarChar(100)
  /// Optional human-friendly label (e.g. "Room 204 – Sept checkout")
  name             String?   @db.VarChar(200)
  /// draft | checked_out | partially_returned | returned
  status           String    @default("draft")
  /// DEPRECATED: kept for backward compat — use DeviceCartUser join table instead
  assignedToUserId String?
  /// DEPRECATED: kept for backward compat — always 'staff' for new carts
  assigneeType     String?
  /// Location at checkout time (used for all assignments)
  locationId       String?
  dueDate          DateTime?
  checkoutCondition String?
  notes            String?   @db.Text
  createdById      String
  committedAt      DateTime?
  committedById    String?
  fullyReturnedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedToUser   User?          @relation("CartAssignedToUser",  fields: [assignedToUserId], references: [id])
  location         OfficeLocation? @relation(fields: [locationId],  references: [id], onDelete: SetNull)
  createdBy        User           @relation("CartCreatedBy",        fields: [createdById],      references: [id])
  committedBy      User?          @relation("CartCommittedBy",      fields: [committedById],    references: [id])
  items            DeviceCartItem[]
  assignments      DeviceAssignment[]
  users            DeviceCartUser[]

  @@index([tagNumber])
  @@index([status])
  @@index([assignedToUserId])
  @@index([locationId])
  @@index([createdById])
  @@index([committedAt])
  @@map("device_carts")
}

/// One device staged inside a DeviceCart.
/// After commitCart() the assignmentId FK is populated and the cart item becomes
/// a permanent audit trail linking the assignment back to the cart.
model DeviceCartItem {
  id           String    @id @default(uuid())
  cartId       String
  equipmentId  String
  /// Set after commitCart() — links to the DeviceAssignment created for this item
  assignmentId String?   @unique
  condition    String?
  notes        String?   @db.Text
  sortOrder    Int       @default(0)
  addedAt      DateTime  @default(now())

  cart         DeviceCart        @relation(fields: [cartId],       references: [id], onDelete: Cascade)
  equipment    equipment         @relation(fields: [equipmentId],  references: [id])
  assignment   DeviceAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@unique([cartId, equipmentId])
  @@index([cartId])
  @@index([equipmentId])
  @@index([assignmentId])
  @@map("device_cart_items")
}

/// Staff users assigned to a DeviceCart (many-to-many join with role).
/// Replaces the former DeviceCart.assignedToUserId single-FK.
model DeviceCartUser {
  id        String   @id @default(uuid())
  cartId    String
  userId    String
  /// "primary" = receives DeviceAssignment records at commit time.
  /// "secondary" = co-holder; shown in UI but no individual assignments.
  role      String   @default("primary")
  addedAt   DateTime @default(now())

  cart      DeviceCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  user      User       @relation("DeviceCartUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cartId, userId])
  @@index([cartId])
  @@index([userId])
  @@map("device_cart_users")
}

// ============================================
// TRANSPORTATION MODULE
// ============================================

model TransportationUnit {
  id             String   @id @default(uuid())
  unitNumber     String   @unique @db.VarChar(50)
  vin            String?  @unique @db.VarChar(17)
  year           Int?
  make           String?
  model          String?
  type           String   // REGULAR_BUS | SPECIAL_EDUCATION_BUS | MINIBUS | CAR | TRUCK | VAN | OTHER
  fuelType       String   // GASOLINE | DIESEL | ELECTRIC | PROPANE | CNG | OTHER
  currentMileage Int      @default(0)
  capacity       Int?
  licensePlate   String?
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments TransportationUnitAssignment[]
  fuelEntries FuelConsumptionEntry[]

  @@index([unitNumber])
  @@index([type])
  @@index([fuelType])
  @@index([isActive])
  @@map("transportation_units")
}

model TransportationFuelStation {
  id               String   @id @default(uuid())
  officeLocationId String   @unique
  notes            String?
  isActive         Boolean  @default(true)
  addedById        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  officeLocation OfficeLocation       @relation(fields: [officeLocationId], references: [id])
  addedBy        User                 @relation(fields: [addedById], references: [id])
  fuelEntries    FuelConsumptionEntry[]
  tanks          FuelTank[]

  @@index([officeLocationId])
  @@index([isActive])
  @@map("transportation_fuel_stations")
}

model FuelConsumptionEntry {
  id                   String   @id @default(uuid())
  transportationUnitId String
  enteredById          String
  fuelStationId        String
  tankId               String?
  entryDate            DateTime @default(now())
  fuelAmount           Decimal  @db.Decimal(10, 3)
  fuelUnit             String   @default("gallons")
  mileageAtFueling     Int
  costPerUnit          Decimal? @db.Decimal(10, 4)
  totalCost            Decimal? @db.Decimal(10, 2)
  reportingMonth       String   // YYYY-MM
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  unit        TransportationUnit        @relation(fields: [transportationUnitId], references: [id])
  enteredBy   User                      @relation(fields: [enteredById], references: [id])
  fuelStation TransportationFuelStation @relation(fields: [fuelStationId], references: [id])
  tank        FuelTank?                 @relation(fields: [tankId], references: [id])

  @@index([transportationUnitId])
  @@index([enteredById])
  @@index([fuelStationId])
  @@index([tankId])
  @@index([reportingMonth])
  @@index([entryDate])
  @@index([transportationUnitId, reportingMonth])
  @@index([enteredById, reportingMonth])
  @@map("fuel_consumption_entries")
}

model TransportationUnitAssignment {
  id                   String    @id @default(uuid())
  transportationUnitId String
  userId               String
  isPrimary            Boolean   @default(true)
  assignedAt           DateTime  @default(now())
  assignedById         String
  unassignedAt         DateTime?
  unassignedById       String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  unit         TransportationUnit @relation(fields: [transportationUnitId], references: [id])
  user         User               @relation("TransportationAssignmentUser", fields: [userId], references: [id])
  assignedBy   User               @relation("TransportationAssignmentMadeBy", fields: [assignedById], references: [id])
  unassignedBy User?              @relation("TransportationAssignmentRemovedBy", fields: [unassignedById], references: [id])

  @@index([transportationUnitId])
  @@index([userId])
  @@index([userId, unassignedAt])
  @@index([assignedAt])
  @@map("transportation_unit_assignments")
}

model DotPhysical {
  id                String   @id @default(uuid())
  userId            String
  examDate          DateTime
  expirationDate    DateTime
  examinerId        String?
  examinerCertNumber String?
  certificateNumber String?
  documentUrl       String?
  physicianId       String?
  isActive          Boolean  @default(true)
  remindersSent     Json     @default("[]")
  notes             String?  @db.Text
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  driver    User          @relation("DotPhysicalDriver", fields: [userId], references: [id])
  createdBy User          @relation("DotPhysicalCreator", fields: [createdById], references: [id])
  physician DotPhysician? @relation(fields: [physicianId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expirationDate])
  @@index([isActive])
  @@index([userId, isActive])
  @@index([expirationDate, isActive])
  @@index([physicianId])
  @@map("dot_physicals")
}

model DotPhysician {
  id                     String   @id @default(uuid())
  name                   String   @db.VarChar(200)
  certNumber             String?  @db.VarChar(100)
  nationalRegistryNumber String?  @db.VarChar(100)
  state                  String?  @db.VarChar(2)
  notes                  String?  @db.Text
  isActive               Boolean  @default(true)
  createdById            String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  createdBy    User          @relation("DotPhysicianCreator", fields: [createdById], references: [id])
  dotPhysicals DotPhysical[]

  @@index([name])
  @@index([isActive])
  @@map("dot_physicians")
}

model TransportationSettings {
  id                           String   @id @default("singleton")
  financeDirectorEmail         String?
  directorOfSchoolsEmail       String?
  transportationSecretaryEmails String[] @default([])
  dotPhysicalReminderDays      Json     @default("[60,30,14,7]")
  dotNotificationsEnabled      Boolean  @default(true)
  monthlyFuelReportEnabled     Boolean  @default(true)
  monthlyFuelReportDay         Int      @default(1)
  gasFuelThresholdEnabled      Boolean  @default(false)
  gasFuelThresholdGallons      Decimal? @db.Decimal(10, 2)
  driverLicenseReminderDays         Json     @default("[60,30,14,7]")
  driverLicenseNotificationsEnabled Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@map("transportation_settings")
}

model DriverLicense {
  id             String    @id @default(uuid())
  userId         String
  licenseNumber  String?   @db.VarChar(50)
  licenseState   String?   @db.VarChar(50)
  expirationDate DateTime
  documentUrl    String?
  isActive       Boolean   @default(true)
  remindersSent  Json      @default("[]")
  notes          String?   @db.Text
  uploadedById   String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  driver     User @relation("DriverLicenseHolder",   fields: [userId],       references: [id])
  uploadedBy User @relation("DriverLicenseUploader", fields: [uploadedById], references: [id])

  @@index([userId])
  @@index([expirationDate])
  @@index([isActive])
  @@index([userId, isActive])
  @@index([expirationDate, isActive])
  @@map("driver_licenses")
}

// ============================================
// FUEL TANKS & DELIVERIES
// ============================================

model FuelTank {
  id                    String   @id @default(uuid())
  stationId             String
  label                 String?  @db.VarChar(100)
  fuelType              String   // DIESEL | GASOLINE | PROPANE | BIODIESEL | E85 | CNG | OTHER
  capacityGallons       Decimal  @db.Decimal(10, 2)
  currentFillGallons    Decimal  @db.Decimal(10, 2) @default(0)
  initialFillGallons    Decimal  @db.Decimal(10, 2) @default(0)
  alertThresholdPercent Int      @default(30)
  alertEnabled          Boolean  @default(true)
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  notes                 String?  @db.Text
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  station     TransportationFuelStation @relation(fields: [stationId],   references: [id], onDelete: Cascade)
  createdBy   User                      @relation("FuelTankCreator",     fields: [createdById], references: [id])
  fuelEntries FuelConsumptionEntry[]
  deliveries  FuelTankDelivery[]

  @@index([stationId])
  @@index([fuelType])
  @@index([isActive])
  @@index([stationId, isActive])
  @@map("fuel_tanks")
}

model FuelTankDelivery {
  id               String   @id @default(uuid())
  tankId           String
  enteredById      String
  deliveryDate     DateTime @default(now())
  gallonsDelivered Decimal  @db.Decimal(10, 2)
  vendorName       String?  @db.VarChar(200)
  invoiceNumber    String?  @db.VarChar(100)
  costPerGallon    Decimal? @db.Decimal(10, 4)
  totalCost        Decimal? @db.Decimal(10, 2)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tank      FuelTank @relation(fields: [tankId],      references: [id], onDelete: Cascade)
  enteredBy User     @relation("FuelTankDeliveryEnteredBy", fields: [enteredById], references: [id])

  @@index([tankId])
  @@index([enteredById])
  @@index([deliveryDate])
  @@map("fuel_tank_deliveries")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(100)
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

