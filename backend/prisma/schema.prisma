// ============================================
// UNIFIED TICKETING SYSTEM
// ============================================

enum TicketDepartment {
  TECHNOLOGY
  MAINTENANCE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TechTicketCategory {
  HARDWARE_FAILURE
  SOFTWARE_ISSUE
  NETWORK_CONNECTIVITY
  PRINTING
  PROJECTOR_DISPLAY
  CHROMEBOOK
  DEVICE_SETUP
  PASSWORD_RESET
  ACCOUNT_ACCESS
  OTHER
}

enum MaintTicketCategory {
  PLUMBING
  ELECTRICAL
  HVAC_HEATING
  HVAC_COOLING
  CARPENTRY
  PAINTING
  FLOORING
  PEST_CONTROL
  CLEANING
  DOOR_LOCK
  WINDOW
  ROOF
  GROUNDS
  OTHER
}

model Ticket {
  id               String             @id @default(uuid())
  ticketNumber     String             @unique
  department       TicketDepartment
  status           TicketStatus       @default(OPEN)
  priority         TicketPriority     @default(MEDIUM)
  fiscalYear       String

  // Reporter
  reportedById     String
  reportedBy       User               @relation("TicketReporter", fields: [reportedById], references: [id])

  // Assignee
  assignedToId     String?
  assignedTo       User?              @relation("TicketAssignee", fields: [assignedToId], references: [id])

  // Location
  officeLocationId String?
  officeLocation   OfficeLocation?    @relation(fields: [officeLocationId], references: [id])

  roomId           String?
  room             Room?              @relation(fields: [roomId], references: [id])

  // Issue description
  title            String?
  description      String

  // Category — stored as String; DEPRECATED: kept for legacy data / migration fallback
  category         String?
  // Category FK — preferred: links to WorkOrderCategory for rename-safe display
  categoryId         String?
  workOrderCategory  WorkOrderCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Technology-specific (nullable, only populated for TECHNOLOGY dept)
  equipmentId      String?
  equipment        equipment?         @relation("TicketEquipment", fields: [equipmentId], references: [id])

  // Maintenance-specific (nullable, only populated for MAINTENANCE dept)
  equipmentMfg     String?
  equipmentModel   String?
  equipmentSerial  String?

  // Timestamps
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resolvedAt       DateTime?
  closedAt         DateTime?

  // Relations
  comments         TicketComment[]
  statusHistory    TicketStatusHistory[]

  @@index([department])
  @@index([status])
  @@index([priority])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([officeLocationId])
  @@index([roomId])
  @@index([fiscalYear])
  @@index([department, status])
  @@index([officeLocationId, department, status])
  @@index([categoryId])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User     @relation("TicketCommentAuthor", fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_comments")
}

model TicketStatusHistory {
  id          String        @id @default(uuid())
  ticketId    String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String
  changedAt   DateTime      @default(now())
  notes       String?

  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy   User          @relation("TicketStatusChangedBy", fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedAt])
  @@map("ticket_status_history")
}

// ============================================
// STANDALONE TRANSPORTATION REQUESTS
// ============================================

model TransportationRequest {
  id            String   @id @default(uuid())

  // Submitter (auto-populated from JWT)
  submittedById String
  submittedBy   User     @relation("TransportationRequestSubmitter", fields: [submittedById], references: [id])

  // FK to OfficeLocation for supervisor routing
  officeLocationId       String?
  officeLocation         OfficeLocation? @relation(fields: [officeLocationId], references: [id])

  // Part A — Requestor fills out (mirrors PDF form)
  dateSubmitted          DateTime  @default(now())
  school                 String    @db.VarChar(200)
  groupOrActivity        String    @db.VarChar(300)
  sponsorName            String    @db.VarChar(200)
  chargedTo              String?   @db.VarChar(300)
  tripDate               DateTime
  busCount               Int
  studentCount           Int
  chaperoneCount         Int
  needsDriver            Boolean   @default(true)
  driverName             String?   @db.VarChar(200)

  // Location & times
  loadingLocation        String    @db.VarChar(500)
  loadingTime            String    @db.VarChar(20)
  leavingSchoolTime      String    @db.VarChar(20)
  arriveFirstDestTime    String?   @db.VarChar(20)
  leaveLastDestTime      String?   @db.VarChar(20)
  returnToSchoolTime     String    @db.VarChar(20)

  // Destinations (supports multiple stops)
  primaryDestinationName    String  @db.VarChar(500)
  primaryDestinationAddress String  @db.VarChar(500)
  additionalDestinations    Json?   // Array of { name: string; address: string }

  // Free-text notes
  tripItinerary          String?   @db.Text

  // Workflow
  status                 String    @default("PENDING_SUPERVISOR_APPROVAL")
  // PENDING_SUPERVISOR_APPROVAL | PENDING_SECRETARY_REVIEW | APPROVED | DENIED

  // Supervisor approval fields
  supervisorApprovedById  String?
  supervisorApprovedAt    DateTime?
  supervisorApprovedBy    User?     @relation("TransportationRequestSupervisorApprover", fields: [supervisorApprovedById], references: [id])
  supervisorDeniedById    String?
  supervisorDeniedAt      DateTime?
  supervisorDenialReason  String?   @db.Text
  supervisorDeniedBy      User?     @relation("TransportationRequestSupervisorDenier", fields: [supervisorDeniedById], references: [id])
  supervisorEmailSnapshot String?   @db.VarChar(500)

  // Approval/Denial fields (set by Transportation Secretary)
  approvalComments       String?   @db.Text
  assignedDriverNames    String[]
  approvedById           String?
  approvedAt             DateTime?
  deniedById             String?
  deniedAt               DateTime?
  denialReason           String?   @db.Text

  // Snapshot of submitter email (for notifications at approval/denial time)
  submitterEmail         String

  // Timestamps
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  approvedBy             User?     @relation("TransportationRequestApprover", fields: [approvedById], references: [id])
  deniedBy               User?     @relation("TransportationRequestDenier", fields: [deniedById], references: [id])

  @@index([status])
  @@index([submittedById])
  @@index([tripDate])
  @@index([status, submittedById])
  @@index([officeLocationId])
  @@map("transportation_requests")
}

model JobSchedule {
  id            String    @id @default(cuid())
  jobKey        String    @unique
  cronExpr      String
  enabled       Boolean   @default(false)
  lastRunAt     DateTime?
  lastRunStatus String?
  lastRunResult Json?
  nextRunAt     DateTime?
  updatedBy     String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  @@map("job_schedules")
}

/// Email queue for reliable async delivery with rate limiting and retry logic.
model email_queue {
  id              String   @id @default(uuid()) @db.Uuid

  /// Recipient email addresses
  recipients      String[]

  /// Email subject line
  subject         String

  /// Rendered HTML body (ready to send)
  htmlBody        String   @db.Text

  /// Optional email attachments.
  /// Array of: { filename: string; contentType: string; data: string } where data is base64-encoded.
  attachments     Json?

  /// Priority: 1=high, 2=normal, 3=low (numeric for correct sort order)
  priority        Int      @default(2)

  /// Current status: 'pending', 'processing', 'sent', 'failed'
  status          String   @default("pending") @db.VarChar(20)

  /// Number of send attempts made
  attempts        Int      @default(0)

  /// When the next retry is eligible (for backoff scheduling)
  nextAttemptAt   DateTime @default(now())

  /// Timestamp when successfully sent
  sentAt          DateTime?

  /// Last error message (for debugging failed emails)
  lastError       String?  @db.Text

  /// Optional context label (e.g., "po_approval", "field_trip_submit")
  context         String?  @db.VarChar(100)

  /// Optional related entity ID for audit trail
  relatedEntityId String?  @db.Uuid

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([status, createdAt])
  @@index([relatedEntityId])
}

// ============================================
// WORK ORDER CATEGORIES
// ============================================

enum WorkOrderCategoryModule {
  TECHNOLOGY
  MAINTENANCE
}

model WorkOrderCategory {
  id        String                  @id @default(uuid())
  name      String
  module    WorkOrderCategoryModule
  isActive  Boolean                 @default(true)
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  tickets   Ticket[]

  @@unique([name, module])
  @@index([module, isActive])
  @@index([module, sortOrder])
  @@map("work_order_categories")
}

// ============================================
// DEVICE MANAGEMENT (MANAGE1TO1 REPLACEMENT)
// ============================================

/// Checkout / check-in record for a device assigned to any User (student or staff).
/// Only one active (returnedAt IS NULL) assignment per equipment item is allowed.
model DeviceAssignment {
  id                String    @id @default(uuid())
  equipmentId       String
  userId            String    // FK → User — the person holding the device (student or staff)
  assigneeType      String    // "student" | "staff" — drives UI display and reports
  checkoutBy        String    // User.id — technician who performed the checkout
  checkoutAt        DateTime  @default(now())
  checkoutCondition String    // "perfect" | "good" | "fair" | "damaged"
  returnedAt        DateTime?
  returnCondition   String?   // "perfect" | "good" | "fair" | "damaged"
  returnedBy        String?   // User.id — technician who processed the return
  notes             String?
  returnNotes       String?
  locationId        String?   // FK → OfficeLocation — user's location at checkout time
  /// FK → DeviceCart — set when this assignment was created through a cart checkout.
  /// NULL for single-device checkouts.
  cartId            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  equipment        equipment        @relation(fields: [equipmentId], references: [id])
  user             User             @relation("DeviceAssignmentUser", fields: [userId], references: [id])
  checkedOutByUser User             @relation("DeviceAssignmentCheckedOutBy", fields: [checkoutBy], references: [id])
  returnedByUser   User?            @relation("DeviceAssignmentReturnedBy", fields: [returnedBy], references: [id])
  location         OfficeLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  cart             DeviceCart?      @relation(fields: [cartId], references: [id], onDelete: SetNull)
  damageIncidents  DamageIncident[]
  cartItem         DeviceCartItem?

  @@index([equipmentId])
  @@index([userId])
  @@index([assigneeType])
  @@index([checkoutAt])
  @@index([returnedAt])
  @@index([equipmentId, returnedAt])
  @@index([locationId])
  @@index([cartId])
  @@map("device_assignments")
}

model DamageIncident {
  id              String    @id @default(uuid())
  incidentNumber  String?   @unique
  equipmentId     String?   // Nullable — wizard supports user-only incidents (no device)
  assignmentId    String?   // FK → DeviceAssignment (null for walk-in with no active checkout)
  userId          String?   // FK → User — the student/staff member responsible (denormalised)
  reportedBy      String    // User.id — technician who logged the incident
  reportedAt      DateTime  @default(now())
  damageType      String    // "cracked_screen"|"liquid_damage"|"physical_damage"|"missing_keys"|"missing_charger"|"missing_device"|"other"
  severity        String    // "minor"|"moderate"|"severe"|"total_loss"
  description     String?
  estimatedCost   Decimal?  @db.Decimal(10, 2)
  status          String    @default("reported") // "reported"|"invoiced"|"in_repair"|"resolved"|"waived"
  resolvedAt      DateTime?
  resolvedBy      String?   // User.id
  resolutionNotes String?
  schoolYear      String?   // "YYYY-YYYY" school year label, stamped at rollover
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// Actual date the damage occurred (user-selected in wizard Step 1).
  /// Distinct from reportedAt which is set automatically to now().
  damageDate      DateTime?

  /// Whether the damage was accidental or intentional.
  /// 'accidental' → sends to repair before invoice
  /// 'intentional' → skips repair, goes directly to invoice
  intent          String?   // 'accidental' | 'intentional'

  /// Current step in the unified incident workflow wizard.
  /// DAMAGE_REPORTED → PENDING_REPAIR → IN_REPAIR → REPAIR_COMPLETE → INVOICED → CLOSED
  workflowStep    String?   // see IncidentWorkflowStep type

  equipment     equipment?            @relation(fields: [equipmentId], references: [id])
  assignment    DeviceAssignment?     @relation(fields: [assignmentId], references: [id])
  user          User?                 @relation("DamageIncidentUser", fields: [userId], references: [id])
  reporter      User                  @relation("DamageIncidentReporter", fields: [reportedBy], references: [id])
  resolvedUser  User?                 @relation("DamageIncidentResolver", fields: [resolvedBy], references: [id])
  photos        DamageIncidentPhoto[]
  repairTickets RepairTicket[]
  invoices      DamageInvoice[]

  @@index([equipmentId])
  @@index([assignmentId])
  @@index([userId])
  @@index([status])
  @@index([reportedAt])
  @@index([incidentNumber])
  @@index([schoolYear])
  @@index([intent])
  @@index([workflowStep])
  @@index([damageDate])
  @@map("damage_incidents")
}

model DamageIncidentPhoto {
  id         String   @id @default(uuid())
  incidentId String
  fileName   String
  fileUrl    String
  fileType   String   // "image/jpeg"|"image/png"|"image/webp"
  fileSize   Int      // bytes
  uploadedBy String   // User.id
  uploadedAt DateTime @default(now())

  incident DamageIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploader User           @relation(fields: [uploadedBy], references: [id])

  @@index([incidentId])
  @@map("damage_incident_photos")
}

model RepairTicket {
  id                 String    @id @default(uuid())
  ticketNumber       String    @unique // RT-{YEAR}-{SEQUENCE}
  equipmentId        String
  damageIncidentId   String?   // Optional — routine repairs have no incident
  vendorId           String?   // FK → vendors
  createdBy          String    // User.id
  status             String    @default("pending") // "pending"|"sent_to_vendor"|"in_repair"|"returned"|"unrepairable"|"cancelled"
  sentForRepairAt    DateTime?
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  repairCost         Decimal?  @db.Decimal(10, 2)
  trackingNumber     String?
  repairNotes        String?
  internalNotes      String?
  schoolYear         String?   // "YYYY-YYYY" school year label, stamped at rollover
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  equipment      equipment       @relation(fields: [equipmentId], references: [id])
  damageIncident DamageIncident? @relation(fields: [damageIncidentId], references: [id])
  vendor         vendors?        @relation(fields: [vendorId], references: [id])
  creator        User            @relation("RepairTicketCreator", fields: [createdBy], references: [id])

  @@index([equipmentId])
  @@index([damageIncidentId])
  @@index([vendorId])
  @@index([status])
  @@index([sentForRepairAt])
  @@index([schoolYear])
  @@map("repair_tickets")
}

/// Invoice sent to a parent/guardian email for a damage incident.
/// Recipient contact info is entered manually at invoice creation — no guardian DB record.
model DamageInvoice {
  id               String    @id @default(uuid())
  invoiceNumber    String    @unique  // INV-{YEAR}-{SEQUENCE}
  damageIncidentId String
  userId           String?   // FK → User — the student the invoice is for (if applicable)
  recipientEmail   String    // Parent/guardian email — manually entered
  recipientName    String?   // Display name for email greeting
  parentEmail      String?   // Secondary parent/guardian email
  amount           Decimal   @db.Decimal(10, 2)
  dueDate          DateTime
  status           String    @default("draft") // "draft"|"sent"|"paid"|"waived"|"collections"
  sentAt           DateTime?
  paidAt           DateTime?
  notes            String?
  createdBy        String    // User.id
  schoolYear       String?   // "YYYY-YYYY" school year label, stamped at rollover
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  damageIncident DamageIncident  @relation(fields: [damageIncidentId], references: [id])
  user           User?           @relation("DamageInvoiceUser", fields: [userId], references: [id])
  creator        User            @relation("DamageInvoiceCreator", fields: [createdBy], references: [id])
  payments       InvoicePayment[]
  lineItems      DamageInvoiceLineItem[]

  @@index([damageIncidentId])
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([schoolYear])
  @@map("damage_invoices")
}

model InvoicePayment {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Decimal  @db.Decimal(10, 2)
  paidAt        DateTime
  paymentMethod String?  // "cash"|"check"|"online"|"other"
  checkNumber   String?
  notes         String?
  recordedBy    String   // User.id
  createdAt     DateTime @default(now())

  invoice  DamageInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recorder User          @relation(fields: [recordedBy], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
  @@map("invoice_payments")
}

/// Global reference table of component replacement prices for damage invoicing.
/// Prices are global (not per-device-type) for simplicity in a K-12 district context.
model DamageComponentPrice {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String   @default("Other")
  description String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lineItems   DamageInvoiceLineItem[]

  @@index([isActive])
  @@map("damage_component_prices")
}

/// Line items attached to a DamageInvoice, replacing the flat amount field.
model DamageInvoiceLineItem {
  id               String                @id @default(uuid())
  invoiceId        String
  componentPriceId String?
  description      String
  unitPrice        Decimal               @db.Decimal(10, 2)
  quantity         Int                   @default(1)
  lineTotal        Decimal               @db.Decimal(10, 2)
  isReplacement    Boolean               @default(false)
  createdAt        DateTime              @default(now())

  invoice          DamageInvoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  componentPrice   DamageComponentPrice? @relation(fields: [componentPriceId], references: [id])

  @@index([invoiceId])
  @@map("damage_invoice_line_items")
}

// ============================================
// DEVICE MANAGEMENT YEAR ROLLOVER AUDIT
// ============================================

model DmYearRolloverHistory {
  id               String   @id @default(uuid())
  schoolYear       String   // Outgoing year archived, e.g. "2025-2026"
  newSchoolYear    String   @unique  // Incoming year started — unique prevents double rollover
  schoolYearStart  DateTime
  schoolYearEnd    DateTime
  incidentsStamped Int      @default(0)
  ticketsStamped   Int      @default(0)
  invoicesStamped  Int      @default(0)
  performedById    String
