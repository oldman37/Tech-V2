# Environment Configuration
NODE_ENV=development
PORT=3000
TZ=America/New_York

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/tech_v2"

# JWT — use separate secrets so access and refresh tokens cannot be substituted for each other
JWT_ACCESS_SECRET="your-access-token-secret-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this-in-production"
JWT_EXPIRES_IN="1h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Microsoft Entra ID (Azure AD)
ENTRA_TENANT_ID="your-tenant-id"
ENTRA_CLIENT_ID="your-client-id"
ENTRA_CLIENT_SECRET="your-client-secret"
REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Entra Group IDs — Role / module access
ENTRA_ADMIN_GROUP_ID="admin-group-object-id"
ENTRA_PRINCIPALS_GROUP_ID="principals-group-object-id"
ENTRA_VICE_PRINCIPALS_GROUP_ID="vice-principals-group-object-id"
ENTRA_DIRECTOR_OF_SCHOOLS_GROUP_ID="director-of-schools-group-object-id"
ENTRA_ASST_DIRECTOR_OF_SCHOOLS_GROUP_ID="asst-director-of-schools-group-object-id"
ENTRA_FINANCE_DIRECTOR_GROUP_ID="finance-director-group-object-id"
ENTRA_FINANCE_PO_ENTRY_GROUP_ID="finance-po-entry-group-object-id"
ENTRA_SPED_DIRECTOR_GROUP_ID="sped-director-group-object-id"
ENTRA_TECHNOLOGY_DIRECTOR_GROUP_ID="technology-director-group-object-id"
ENTRA_TECH_ASSISTANTS_GROUP_ID="tech-assistants-group-object-id"
ENTRA_MAINTENANCE_DIRECTOR_GROUP_ID="maintenance-director-group-object-id"
ENTRA_SCHOOL_MAINTENANCE_GROUP_ID="school-maintenance-group-object-id"
ENTRA_TRANSPORTATION_DIRECTOR_GROUP_ID="transportation-director-group-object-id"
ENTRA_TRANSPORTATION_SECRETARY_GROUP_ID="transportation-secretary-group-object-id"
ENTRA_AFTERSCHOOL_DIRECTOR_GROUP_ID="afterschool-director-group-object-id"
ENTRA_NURSE_DIRECTOR_GROUP_ID="nurse-director-group-object-id"
ENTRA_PRE_K_DIRECTOR_GROUP_ID="pre-k-director-group-object-id"
ENTRA_CTE_DIRECTOR_GROUP_ID="cte-director-group-object-id"
ENTRA_FOOD_SERVICES_SUPERVISOR_GROUP_ID="food-services-supervisor-group-object-id"
ENTRA_FOOD_SERVICES_PO_ENTRY_GROUP_ID="food-services-po-entry-group-object-id"
ENTRA_ALL_STAFF_GROUP_ID="all-staff-group-object-id"
ENTRA_ALL_STUDENTS_GROUP_ID="all-students-group-object-id"

# Email Configuration (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM="Tech Department <tech@example.com>"

# Email queue worker tuning (optional — defaults used if omitted)
EMAIL_QUEUE_POLL_INTERVAL_MS=5000
EMAIL_QUEUE_SEND_INTERVAL_MS=500
EMAIL_QUEUE_MAX_ATTEMPTS=3
EMAIL_QUEUE_BACKOFF_BASE_MS=60000

# Application
APP_URL="https://your-app-domain.com"
DISTRICT_NAME="Your School District"

# Cron schedule (cron expression — default: 0 2 * * * = 2 AM daily)
SUPERVISOR_SYNC_SCHEDULE="0 2 * * *"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL="info"
# Set to "true" to write logs to files in addition to stdout
LOG_TO_FILE=false

# CORS
CORS_ORIGIN="http://localhost:5173"
