# =============================================================================
# Tech-V2 — Root Environment Configuration
#
# Copy this file to .env and fill in all required values before running
# docker compose up.  The docker-compose files read variables from this file
# via compose's automatic .env interpolation.
#
# Variables marked REQUIRED must be set or the backend will refuse to start.
# Variables marked OPTIONAL have defaults shown; omit them to use the default.
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL credentials used by docker-compose to create the database and to
# assemble the DATABASE_URL connection string passed to the backend container.
# REQUIRED
DB_USER=techv2
# REQUIRED
DB_PASSWORD=change-me-in-production

# =============================================================================
# SERVER
# =============================================================================

# Node.js environment: development | production | test
# OPTIONAL — default: development
NODE_ENV=production

# Port the backend HTTP server listens on inside the container.
# OPTIONAL — default: 3000
PORT=3000

# Timezone used by node-cron schedules and log timestamps.
# OPTIONAL — default: America/Chicago
TZ=America/Chicago

# Comma-separated list of allowed CORS origins.
# OPTIONAL — default: http://localhost:5173
CORS_ORIGIN=https://your-app-domain.com

# Public URL of the application (used in email links).
# REQUIRED for email links to work correctly.
APP_URL=https://your-app-domain.com

# Display name of the district, used in invoice PDFs.
# OPTIONAL — default: Technology Department
DISTRICT_NAME=Your School District

# =============================================================================
# JWT SECRETS
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use DIFFERENT values for access and refresh tokens.
# =============================================================================

# REQUIRED
JWT_ACCESS_SECRET=replace-with-a-64-byte-random-hex-string

# REQUIRED
JWT_REFRESH_SECRET=replace-with-a-different-64-byte-random-hex-string

# Access token lifetime (ms, s, m, h, d — e.g. "1h", "15m").
# OPTIONAL — default: 1h
JWT_EXPIRES_IN=1h

# Refresh token lifetime.
# OPTIONAL — default: 7d
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# MICROSOFT ENTRA ID (Azure AD)
# =============================================================================

# OAuth application credentials — from the Azure portal App Registration.
# REQUIRED
ENTRA_TENANT_ID=your-azure-tenant-id

# REQUIRED
ENTRA_CLIENT_ID=your-azure-app-client-id

# REQUIRED
ENTRA_CLIENT_SECRET=your-azure-app-client-secret

# OAuth callback URI registered in the Azure portal.
# Must match exactly (including trailing path).
# REQUIRED
REDIRECT_URI=https://your-app-domain.com/api/auth/callback

# How long (milliseconds) to cache Entra group memberships before re-fetching
# from Microsoft Graph.  Reduces Graph API calls; trades off permission
# revocation latency.  Default = 30 minutes.
# OPTIONAL — default: 1800000
GROUP_MEMBERSHIP_CACHE_TTL_MS=1800000

# =============================================================================
# ENTRA GROUP OBJECT IDs — Role / Module Access
#
# Find these in Azure Portal → Groups → <group> → Object ID.
# All group IDs are OPTIONAL; omitting one disables the role/feature that
# group controls (e.g. omitting ENTRA_ADMIN_GROUP_ID leaves no admin users).
# ENTRA_ADMIN_GROUP_ID is REQUIRED (also enforced by validateEnv).
# =============================================================================

# REQUIRED
ENTRA_ADMIN_GROUP_ID=your-admin-group-object-id

ENTRA_PRINCIPALS_GROUP_ID=your-principals-group-object-id
ENTRA_VICE_PRINCIPALS_GROUP_ID=your-vice-principals-group-object-id
ENTRA_DIRECTOR_OF_SCHOOLS_GROUP_ID=your-director-of-schools-group-object-id
ENTRA_ASST_DIRECTOR_OF_SCHOOLS_GROUP_ID=your-asst-director-of-schools-group-object-id
ENTRA_FINANCE_DIRECTOR_GROUP_ID=your-finance-director-group-object-id
ENTRA_FINANCE_PO_ENTRY_GROUP_ID=your-finance-po-entry-group-object-id
ENTRA_SPED_DIRECTOR_GROUP_ID=your-sped-director-group-object-id
ENTRA_TECHNOLOGY_DIRECTOR_GROUP_ID=your-technology-director-group-object-id
ENTRA_TECH_ASSISTANTS_GROUP_ID=your-tech-assistants-group-object-id
ENTRA_OCBOE_LIBRARIANS_GROUP_ID=your-ocboe-librarians-group-object-id
ENTRA_MAINTENANCE_DIRECTOR_GROUP_ID=your-maintenance-director-group-object-id
ENTRA_SCHOOL_MAINTENANCE_GROUP_ID=your-school-maintenance-group-object-id
ENTRA_TRANSPORTATION_DIRECTOR_GROUP_ID=your-transportation-director-group-object-id
ENTRA_TRANSPORTATION_SECRETARY_GROUP_ID=your-transportation-secretary-group-object-id
ENTRA_AFTERSCHOOL_DIRECTOR_GROUP_ID=your-afterschool-director-group-object-id
ENTRA_NURSE_DIRECTOR_GROUP_ID=your-nurse-director-group-object-id
ENTRA_PRE_K_DIRECTOR_GROUP_ID=your-pre-k-director-group-object-id
ENTRA_CTE_DIRECTOR_GROUP_ID=your-cte-director-group-object-id
ENTRA_FOOD_SERVICES_SUPERVISOR_GROUP_ID=your-food-services-supervisor-group-object-id
ENTRA_FOOD_SERVICES_PO_ENTRY_GROUP_ID=your-food-services-po-entry-group-object-id
ENTRA_ALL_STAFF_GROUP_ID=your-all-staff-group-object-id
ENTRA_ALL_STUDENTS_GROUP_ID=your-all-students-group-object-id

# =============================================================================
# EMAIL (SMTP)
#
# If any SMTP variable is set, ALL of SMTP_HOST / SMTP_USER / SMTP_PASS must
# be set (partial config is rejected at startup).  Leave all blank to run
# without email delivery.
# =============================================================================

# SMTP server hostname.
SMTP_HOST=smtp.example.com

# SMTP port.  OPTIONAL — default: 587
SMTP_PORT=587

# Use TLS from the start (port 465).  Set false for STARTTLS (port 587).
# OPTIONAL — default: false
SMTP_SECURE=false

# SMTP authentication credentials.
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# From address displayed on outgoing emails.
# OPTIONAL — default: noreply@district.org
SMTP_FROM=Tech Department <tech@example.com>

# =============================================================================
# EMAIL QUEUE TUNING (all OPTIONAL — defaults shown)
# =============================================================================

# Milliseconds between queue poll cycles.
EMAIL_QUEUE_POLL_INTERVAL_MS=30000

# Milliseconds between individual sends within a cycle (throttle).
EMAIL_QUEUE_SEND_INTERVAL_MS=2000

# Maximum send attempts before a message is marked failed.
EMAIL_QUEUE_MAX_ATTEMPTS=5

# Base backoff delay (ms) for the exponential retry schedule.
EMAIL_QUEUE_BACKOFF_BASE_MS=30000

# How often (ms) to clean up old sent/failed queue entries.  Default: 6 hours.
EMAIL_QUEUE_CLEANUP_INTERVAL_MS=21600000

# =============================================================================
# LOGGING
# =============================================================================

# Log level: error | warn | info | http | verbose | debug | silly
# OPTIONAL — default: info (production) / debug (development)
LOG_LEVEL=info

# Set to "true" to write logs to rotating files in addition to stdout.
# OPTIONAL — default: false in development, true in production
LOG_TO_FILE=true

# =============================================================================
# DATABASE BACKUPS
# =============================================================================

# Credentials for the SMB file share where backups are written.
# The share is mounted at /backups inside the backup-cron and backend containers.
# Target share: //10.0.10.83/homes/technology
# REQUIRED for the backup-cron service to start.
SMB_USER=your-smb-username
SMB_PASS=your-smb-password

# How many backup files to keep before pruning older ones.
# OPTIONAL — default: 7
BACKUP_RETAIN_COUNT=7

# Mount path for the backup volume inside containers.
# OPTIONAL — default: /backups
BACKUP_DIR=/backups

# Set to "true" to start the backend in maintenance mode on cold boot.
# Useful when bringing the server back online after a crash to restore the DB
# before allowing user traffic.
# OPTIONAL — default: false
MAINTENANCE_MODE=false

# =============================================================================
# PROVISIONING / SIS SYNC
# =============================================================================

# Path inside the container where the Synergy CSV share is mounted.
# The share SIS_SMB_SHARE is mounted at /sis-data/ via docker-compose.
# REQUIRED for provisioning to run.
SIS_STAFF_CSV=/sis-data/staff.csv
SIS_STUDENT_CSV=/sis-data/students.csv

# CIFS share path for the Synergy CSV files (same server as backup share).
# Uses the same SMB_USER / SMB_PASS credentials already in .env.
# REQUIRED for the /sis-data volume mount to work.
SIS_SMB_SHARE=//10.0.10.83/homes/edupoint

# Comma-separated recipient(s) for the per-run provisioning email report.
# If not set, the report step is silently skipped.
# OPTIONAL
PROVISIONING_REPORT_EMAIL=technology@ocboe.com

# Comma-separated admin email(s) notified when a bulk disable batch is held for approval.
# If not set, the alert email is silently skipped (batch is still created in the DB).
# OPTIONAL
PROVISIONING_ADMIN_EMAIL=admin@ocboe.com

# Maximum number of accounts that can be disabled in a single provisioning run without
# requiring admin approval.  If PASS 3 would disable more than this number in live mode,
# the disables are held in a pending batch and an alert email is sent to PROVISIONING_ADMIN_EMAIL.
# OPTIONAL — default: 50
PROVISIONING_DISABLE_THRESHOLD=50

# When true, all Graph writes are skipped (dry run).
# Report is still sent with [TEST] prefix. Audit rows use DRY_RUN_* actions.
# OPTIONAL — default: true (safe by default; set false only when ready to go live)
PROVISIONING_TEST_MODE=true

# Bootstrap initial passwords for new accounts.
# Used ONLY on the first provisioning run to seed the provisioning_config DB row.
# After that, change passwords via the web UI — these env vars have no effect.
# REQUIRED before the first real (non-test) provisioning run.
PROVISIONING_DEFAULT_STAFF_PASSWORD=
PROVISIONING_DEFAULT_STUDENT_PASSWORD=

# ---------------------------------------------------------------------------
# TEST TENANT OVERRIDE (all OPTIONAL)
#
# When these three vars are set, the provisioning service authenticates against
# a separate (test) Entra tenant instead of the main ENTRA_* tenant.
# All Graph writes (create / update / disable) go to the test tenant.
# PROVISIONING_TEST_MODE can still be combined with this for a full dry run.
# ---------------------------------------------------------------------------
PROVISIONING_TENANT_ID=
PROVISIONING_CLIENT_ID=
PROVISIONING_CLIENT_SECRET=

# Group IDs in the TEST tenant used for the DISABLE pass.
# If not set, falls back to ENTRA_ALL_STAFF_GROUP_ID / ENTRA_ALL_STUDENTS_GROUP_ID.
PROVISIONING_STAFF_GROUP_ID=
PROVISIONING_STUDENT_GROUP_ID=
